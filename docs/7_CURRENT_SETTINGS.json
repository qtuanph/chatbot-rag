{
    "document": {
        "id": "7_CURRENT_SETTINGS",
        "version": "2026-05-25",
        "purpose": "Current project settings snapshot — all defaults, env vars, and runtime parameters. AI reads this for accurate config context."
    },
    "ai_inference": {
        "embedding": {
            "service": "OpenAI-compatible — switchable via Admin → 'Kết nối AI' → tab Embedding",
            "protocol": "OpenAI /v1/embeddings",
            "config_source": "settings.db (SQLite tại /app/data/settings.db) → RuntimeProviderManager overrides Settings.embed_model at startup + on activate",
            "default_active": "TEI container (ai-embedding:80/v1) — is_builtin=1, is_active=1",
            "available_providers": [
                {"name": "tei",       "display": "TEI (Local)",      "url": "http://ai-embedding:80/v1",                    "model": "Alibaba-NLP/gte-multilingual-base",     "builtin": true,  "active_default": true},
                {"name": "openai",    "display": "OpenAI",           "url": "https://api.openai.com/v1",                    "model": "text-embedding-ada-002",               "builtin": false, "active_default": false},
                {"name": "openrouter","display": "OpenRouter",       "url": "https://openrouter.ai/api/v1",                 "model": "openai/text-embedding-3-small",        "builtin": false, "active_default": false},
                {"name": "nvidia",    "display": "NVIDIA NIM",       "url": "https://integrate.api.nvidia.com/v1",          "model": "baai/bge-m3",                          "builtin": false, "active_default": false},
                {"name": "gemini",    "display": "Google Gemini",    "url": "https://generativelanguage.googleapis.com/v1", "model": "text-embedding-004",                   "builtin": false, "active_default": false},
                {"name": "cohere",    "display": "Cohere",           "url": "https://api.cohere.com/v1",                    "model": "embed-multilingual-v3.0",              "builtin": false, "active_default": false}
            ],
            "image": "ghcr.io/huggingface/text-embeddings-inference:turing-1.9",
            "dimensions": 768,
            "context_length": 32768,
            "batch_size": 8,
            "env_fallback": "EMBEDDING_API_BASE=http://ai-embedding:80/v1, EMBEDDING_HF_MODEL=Alibaba-NLP/gte-multilingual-base"
        },
        "reranker": {
            "config_source": "settings.db → RuntimeProviderManager.get_reranker_config() — read per-request (KHÔNG override LlamaIndex Settings, khác với embedding)",
            "default_active": "TEI local (ai-reranker:80) — is_builtin=1, is_active=1",
            "available_providers": [
                {"name": "tei",    "display": "TEI (Local)",  "url": "http://ai-reranker:80",                                                                            "model": "Alibaba-NLP/gte-multilingual-reranker-base",  "builtin": true,  "active_default": true},
                {"name": "nvidia", "display": "NVIDIA NIM",  "url": "https://ai.api.nvidia.com/v1/retrieval/nvidia/llama-nemotron-rerank-1b-v2/reranking",              "model": "nvidia/llama-nemotron-rerank-1b-v2",          "builtin": false, "active_default": false},
                {"name": "cohere", "display": "Cohere",       "url": "https://api.cohere.com",                                                                           "model": "rerank-multilingual-v3.0",                   "builtin": false, "active_default": false}
            ],
            "fallback": "Nếu NVIDIA active nhưng thiếu API key → tự động fallback TEI (logged as warning)"
        },
        "llm_provider": {
            "service": "9Router (built-in, fixed — chỉ có 1 LLM provider, không switch được từ UI)",
            "image": "decolua/9router:latest",
            "url": "http://ai-proxy:2908",
            "interface": "OpenAI-compatible /v1/chat/completions",
            "streaming": "SSE",
            "config_source": "settings.db (is_builtin=1, is_active=1). 9Router-side provider config tại port 2908 Dashboard (SQLite riêng của 9Router — KHÁC settings.db của project)"
        }
    },
    "settings_db": {
        "path": "/app/data/settings.db (env: SETTINGS_DB_DIR)",
        "schema": {
            "ai_providers": "id, service_type (embedding|reranker|llm), provider_name, display_name, url, model, api_key, is_active, is_builtin, priority",
            "api_keys": "id, provider_id FK, key_value, is_active, failure_count, last_used_at — round-robin key pool"
        },
        "api_routes": "/api/v1/settings/providers — CRUD + activate + test + key management (Admin only)",
        "runtime_apply": "RuntimeProviderManager.reload() được gọi sau PUT/activate → LlamaIndex Settings thay đổi ngay in-process, không restart"
    },
    "retrieval": {
        "section_top_k": 99,
        "context_max_chars": 30000,
        "chunk_top_k": 20,
        "chunk_top_k_note": "config.py: retrieval_chunk_top_k=20, retrieval_hybrid_top_k=20",
        "ingestion_chunk_size": 1200,
        "ingestion_chunk_overlap": 150,
        "retrieval_chunk_size": 600,
        "retrieval_chunk_overlap": 120,
        "fetch_multiplier": 5,
        "rerank_enabled": true,
        "rerank_top_k": 10,
        "context_expansion_window": 0,
        "confidence_threshold_high": 0.7,
        "confidence_avg_high": 0.5,
        "confidence_threshold_low": 0.4,
        "semantic_cache_enabled": true,
        "semantic_cache_threshold": 0.08,
        "normalize_enabled": true,
        "max_rerank_candidates": 15,
        "long_context_reorder_enabled": true,
        "hybrid_enabled": true
    },
    "chat": {
        "history_limit": 40,
        "history_redis_ttl": 86400,
        "max_history_messages": 6,
        "session_ttl_days": 30,
        "temperature": 0.3,
        "max_output_tokens": 8192,
        "proxy_timeout": 120.0,
        "stream_timeout": 1800.0,
        "http_max_connections": 50,
        "http_keepalive_connections": 10
    },
    "embedding_pipeline": {
        "batch_size": 8,
        "parallelism": 0,
        "parallelism_note": "0 = auto safe mode. Runtime uses min(4, hardware.embed_parallelism), effectively always >= 1 worker.",
        "vector_store": "qdrant",
        "native_bm25_enabled": false,
        "hybrid_sparse_backend": "qdrant-client Fusion.RRF (dense + fastembed Qdrant/bm25 sparse)",
        "qdrant_url": "http://qdrant:6333",
        "qdrant_collection": "documents_vectors",
        "qdrant_timeout": 30
    },
    "ingestion": {
        "engine": "llamaparse",
        "min_non_empty_nodes": 1,
        "min_total_text_chars": 80,
        "min_quality_score": 0.5,
        "min_section_chars": 200,
        "parsing_timeout": 3600,
        "ocr_languages": ["vi", "en"],
        "chunk_size": 1200,
        "chunk_overlap": 150
    },
    "celery": {
        "task_time_limit": 3600,
        "task_soft_time_limit": 3300,
        "worker_max_memory_kb": 1500000,
        "visibility_timeout": 7200,
        "result_expires": 86400,
        "max_tasks_per_child": 50,
        "retry_backoff": 30,
        "retry_backoff_max": 600,
        "max_retries": 3
    },
    "redis": {
        "url": "redis://redis:6379/0",
        "broker_db": 2,
        "result_db": 1,
        "maxmemory": "512mb",
        "eviction_policy": "allkeys-lru",
        "save": "60 1000",
        "appendonly": true
    },
    "rate_limiting": {
        "global_rpm": 5000,
        "relaxed_mode": true,
        "relaxed_floor": 10000
    },
    "audit": {
        "stream_name": "audit:stream",
        "batch_size": 100,
        "process_interval": 10.0,
        "maxlen": 50000
    },
    "cache": {
        "memory_ttl": 300,
        "doc_ids_ttl": 60.0,
        "max_rerank_candidates": 15,
        "llm_cache_enabled": true,
        "llm_cache_ttl": 14400,
        "llm_cache_exact_first": true
    },
    "usage_tracking": {
        "model_types": ["llm", "embedding", "reranker"],
        "embedding_token_estimate": "chars / 3",
        "reranker_token_estimate": "(query + docs chars) / 3",
        "latency_tracked": true,
        "tracking_method": "celery_fire_and_forget"
    },
    "security": {
        "jwt_algorithm": "HS256",
        "jwt_expire_minutes": 60,
        "jwt_secret_min_length": 32,
        "jwt_secret_min_char_types": 3,
        "max_upload_size_mb": 2048,
        "max_filename_length": 255,
        "allowed_file_types": [
            "application/pdf",
            "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            "text/plain",
            "text/markdown",
            "application/vnd.ms-excel",
            "application/msword"
        ]
    },
    "optional_features": {
        "ragas_evaluation_enabled": false,
        "kg_enabled": false,
        "kg_top_k": 3
    }
}
