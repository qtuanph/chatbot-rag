{
  "document": {
    "id": "7_CURRENT_SETTINGS",
    "version": "2026-05-20",
    "purpose": "Current project settings snapshot — all defaults, env vars, and runtime parameters. AI reads this for accurate config context."
  },
  "ai_inference": {
    "embedding": {
      "service": "ai-embedding (TEI container)",
      "image": "ghcr.io/huggingface/text-embeddings-inference:turing-1.9",
      "model": "Alibaba-NLP/gte-multilingual-base",
      "dimensions": 1024,
      "context_length": 32768,
      "url": "http://ai-embedding:80",
      "port": 7997,
      "gpu_count": 1,
      "max_concurrent_requests": 128,
      "api_endpoint": "POST /embed",
      "request_format": {"inputs": "string | string[]"},
      "response_format": "float[][] (already normalized by TEI)"
    },
    "reranker": {
      "service": "ai-reranker (TEI container)",
      "image": "ghcr.io/huggingface/text-embeddings-inference:turing-1.9",
      "model": "Alibaba-NLP/gte-multilingual-reranker-base",
      "parameters": "306M",
      "context_length": 8192,
      "url": "http://ai-reranker:80",
      "port": 7998,
      "gpu_count": 1,
      "max_concurrent_requests": 128,
      "api_endpoint": "POST /rerank",
      "request_format": {"query": "string", "texts": "string[]", "raw_scores": false},
      "response_format": "[{\"index\": int, \"score\": float}] (sorted desc)"
    },
    "llm_provider": {
      "service": "ai-proxy (9Router)",
      "image": "decolua/9router:latest",
      "url": "http://ai-proxy:2908",
      "port": 2908,
      "interface": "OpenAI-compatible /v1/chat/completions",
      "streaming": "SSE"
    }
  },
  "retrieval": {
    "section_top_k": 5,
    "chunk_top_k": 15,
    "chunk_size": 500,
    "chunk_overlap": 75,
    "fetch_multiplier": 7,
    "rerank_enabled": true,
    "rerank_top_k": 30,
    "context_expansion_window": 1,
    "bm25_k1": 1.5,
    "bm25_b": 0.75,
    "bm25_singleton_ttl": 120.0,
    "bm25_rebuild_batch_size": 500,
    "confidence_threshold_high": 0.7,
    "confidence_avg_high": 0.5,
    "confidence_threshold_low": 0.4,
    "query_refinement_enabled": false,
    "query_refinement_ttl": 600,
    "query_refinement_timeout": 2.0,
    "query_expansion_enabled": false,
    "query_expansion_variants": 2,
    "query_expansion_timeout": 3.0,
    "expansion_scroll_limit": 100,
    "semantic_cache_enabled": true,
    "semantic_cache_threshold": 0.08,
    "normalize_enabled": true
  },
  "chat": {
    "history_limit": 40,
    "history_redis_ttl": 86400,
    "max_history_messages": 10,
    "session_ttl_days": 30,
    "temperature": 0.3,
    "max_output_tokens": 8192,
    "proxy_timeout": 120.0,
    "stream_timeout": 1800.0,
    "http_timeout_refine": 30.0,
    "http_keepalive_expiry": 30.0,
    "http_max_connections": 50,
    "http_keepalive_connections": 10
  },
  "embedding_pipeline": {
    "batch_size": 32,
    "chunk_size": 32,
    "parallelism": 0,
    "vector_store": "qdrant",
    "qdrant_url": "http://qdrant:6333",
    "qdrant_collection": "documents_vectors",
    "qdrant_timeout": 30,
    "qdrant_group_size": 3
  },
  "ingestion": {
    "engine": "docling",
    "min_non_empty_nodes": 1,
    "min_total_text_chars": 80,
    "min_quality_score": 0.5,
    "min_section_chars": 200,
    "chunk_token_to_char_multiplier": 3,
    "parsing_timeout": 3600,
    "ocr_languages": ["vi", "en"]
  },
  "celery": {
    "task_time_limit": 3600,
    "task_soft_time_limit": 3300,
    "worker_max_memory_kb": 1500000,
    "visibility_timeout": 7200,
    "result_expires": 86400,
    "max_tasks_per_child": 50,
    "retry_backoff": 30,
    "retry_backoff_max": 600,
    "max_retries": 3
  },
  "redis": {
    "url": "redis://redis:6379/0",
    "broker_db": 2,
    "result_db": 1,
    "maxmemory": "512mb",
    "eviction_policy": "allkeys-lru",
    "save": "60 1000",
    "appendonly": true
  },
  "rate_limiting": {
    "global_rpm": 5000,
    "relaxed_mode": true,
    "relaxed_floor": 10000
  },
  "audit": {
    "stream_name": "audit:stream",
    "batch_size": 100,
    "process_interval": 10.0,
    "maxlen": 50000
  },
  "cache": {
    "memory_ttl": 300,
    "doc_ids_ttl": 60.0,
    "max_rerank_candidates": 30,
    "llm_cache_enabled": true,
    "llm_cache_ttl": 14400,
    "llm_cache_exact_first": true
  },
  "security": {
    "jwt_algorithm": "HS256",
    "jwt_expire_minutes": 60,
    "jwt_secret_min_length": 32,
    "jwt_secret_min_char_types": 3,
    "max_upload_size_mb": 2048,
    "max_filename_length": 255,
    "allowed_file_types": [
      "application/pdf",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
      "text/plain",
      "text/markdown",
      "application/vnd.ms-excel",
      "application/msword"
    ]
  },
  "optional_features": {
    "ragas_evaluation_enabled": false,
    "kg_enabled": false,
    "kg_top_k": 3
  },
  "removed_features": {
    "hyde": "Removed 2026-05-20 — latency high, caused hallucination noise",
    "context_compaction": "Removed 2026-05-20 — replaced by AI_MAX_HISTORY_MESSAGES (default 10)",
    "ai_engine": "Removed 2026-05-20 — replaced by TEI containers (ai-embedding, ai-reranker)",
    "sentence_transformers": "Removed from requirements.txt — embedding via TEI HTTP",
    "torch": "Removed from requirements.txt — no longer needed, pynvml handles GPU detection",
    "websocket_chat": "Replaced by SSE streaming via POST /chat/stream"
  }
}
