{
  "document": {
    "id": "7_CURRENT_SETTINGS",
    "version": "2026-06-04",
    "purpose": "Snapshot cấu hình hiện tại sau refactor multi-tenant + stateless chat."
  },
  "architecture": {
    "mode": "multi-tenant",
    "chat_mode": "stateless",
    "primary_roles": ["platform_admin", "tenant_admin"],
    "browser_api_rule": "Browser business requests must go through /api/bep/*"
  },
  "providers": {
    "embedding_default": {
      "provider": "dmr",
      "url": "http://model-runner.docker.internal:12434/engines/v1",
      "model": "ai/qwen3-embedding:0.6B-F16",
      "vector_size": 1024
    },
    "reranker_default": {
      "provider": "nvidia",
      "url": "https://ai.api.nvidia.com/v1/retrieval/nvidia/llama-nemotron-rerank-1b-v2/reranking",
      "model": "nvidia/llama-nemotron-rerank-1b-v2"
    },
    "reranker_local_fallback": {
      "provider": "dmr",
      "url": "http://model-runner.docker.internal:12434",
      "model": "ai/qwen3-reranker:0.6B"
    },
    "llm_default": {
      "provider": "9router",
      "url": "http://ai-proxy:2908",
      "model": "chatbot-rag"
    }
  },
  "ingestion": {
    "worker_mode": "celery background task",
    "document_progress_storage": "documents.status/status_stage/progress_percent",
    "frontend_progress_mode": "polling every ~4 seconds",
    "is_true_realtime": false,
    "ingestion_chunk_size": 1200,
    "ingestion_chunk_overlap": 150,
    "embedding_batch_size": 8,
    "pipeline_batch_size": 1,
    "note": "batch_size=1 ở ingestion pipeline là một nguyên nhân làm embed/index chậm"
  },
  "chat": {
    "history_persistence": false,
    "client_context_window_messages": 6,
    "temperature": 0.3,
    "max_output_tokens": 8192,
    "internal_chat_route": "/api/v1/chat/stream",
    "public_chat_route": "/api/v1/public/v1/chat/completions"
  },
  "usage_tracking": {
    "currency_code": "VND",
    "cost_storage": "cost_micros_vnd",
    "tracked_model_types": ["llm", "embedding", "reranker"]
  },
  "storage": {
    "database": "PostgreSQL",
    "vector_db": "Qdrant",
    "cache_queue": "Redis",
    "object_storage": "RustFS",
    "settings_db": "/app/data/settings.db"
  },
  "deployment": {
    "reverse_proxy": "Traefik",
    "webapp_proxy_base": "/api/bep",
    "api_internal_url": "http://api:8000/api/v1",
    "ai_proxy_service": "ai-proxy",
    "docker_model_runner_host": "model-runner.docker.internal"
  }
}
