{
  "document": {
    "id": "00_QUICK_REFERENCE",
    "version": "2026-04-21",
    "purpose": "Rules and patterns cheat sheet for fast AI/agent preflight.",
    "authority": "This file is the quick-reference entrypoint. docs/ remains the source of truth."
  },
  "core_invariants": [
    {
      "name": "async_ingestion",
      "rule": "Upload returns task_id immediately. Parsing/indexing runs asynchronously via Celery workers."
    },
    {
      "name": "two_stage_retrieval",
      "rule": "Query -> single Qdrant fetch -> in-memory section grouping (>=0.30) -> chunk re-ranking within sections (>=0.35). Doc IDs TTL-cached 60s."
    },
    {
      "name": "hard_delete_order",
      "rule": "registry -> vectors -> file -> database -> purge"
    }
  ],
  "data_location_map": [
    {
      "data": "sections",
      "storage": "PostgreSQL",
      "table": "document_sections",
      "query_layer": "SectionRepository",
      "notes": "Level-1 structure and canonical order source"
    },
    {
      "data": "chunks",
      "storage": "Qdrant",
      "query_layer": "qdrant.py adapter",
      "notes": "~400 token chunks with section_id metadata"
    },
    {
      "data": "documents",
      "storage": "PostgreSQL",
      "table": "documents",
      "notes": "status lifecycle: pending/processing/ready/deleted"
    },
    {
      "data": "chat_history",
      "storage": "Redis",
      "query_layer": "ChatStore",
      "notes": "TTL 24h with beat cleanup"
    },
    {
      "data": "uploaded_files",
      "storage": "RustFS",
      "query_layer": "DocumentStore",
      "notes": "Hard-deleted on user delete request"
    },
    {
      "data": "query_embedding_cache",
      "storage": "Redis",
      "query_layer": "QueryEmbeddingCache",
      "notes": "MD5 keyed; TTL 1 hour"
    },
    {
      "data": "user_sessions",
      "storage": "JWT + Redis blacklist",
      "query_layer": "TokenBlacklist",
      "notes": "Token revocation on logout"
    },
    {
      "data": "user_memories",
      "storage": "PostgreSQL + Redis cache (5min TTL)",
      "table": "user_memories",
      "query_layer": "UserMemoryService",
      "notes": "Persistent per-user facts/preferences/corrections injected into AI system prompt"
    }
  ],
  "critical_env": {
    "ai_embedding": {
      "AI_PROVIDER": "google|vllm",
      "GOOGLE_API_KEY": "required if AI_PROVIDER=google",
      "GOOGLE_MODEL": "gemma-4-26b-a4b-it",
      "EMBEDDING_HF_MODEL": "BAAI/bge-m3"
    },
    "retrieval_thresholds": {
      "RETRIEVAL_SECTION_MIN_SCORE": 0.3,
      "RETRIEVAL_MIN_SCORE": 0.35,
      "RETRIEVAL_SECTION_TOP_K": 3,
      "RETRIEVAL_CHUNK_TOP_K": 5
    },
    "ingestion": {
      "INGESTION_ENGINE": "docling|classic",
      "INGESTION_EMBEDDING_CHUNK_SIZE": 32
    },
    "production_safety": {
      "ALLOWED_HOSTS": "must be explicit",
      "CORS_ORIGINS": "must be explicit",
      "S3_SECURE": true,
      "RATE_LIMIT_RELAXED_MODE": false
    }
  },
  "api_summary": {
    "base": "/api/v1",
    "routes": [
      {
        "method": "POST",
        "path": "/auth/login",
        "auth": "public"
      },
      {
        "method": "POST",
        "path": "/auth/logout",
        "auth": "jwt"
      },
      {
        "method": "GET",
        "path": "/auth/me",
        "auth": "jwt"
      },
      {
        "method": "POST",
        "path": "/auth/users",
        "auth": "admin"
      },
      {
        "method": "GET",
        "path": "/auth/users",
        "auth": "admin"
      },
      {
        "method": "POST",
        "path": "/upload",
        "auth": "admin",
        "returns": "task_id"
      },
      {
        "method": "GET",
        "path": "/status/{task_id}",
        "auth": "jwt"
      },
      {
        "method": "GET",
        "path": "/documents",
        "auth": "member"
      },
      {
        "method": "DELETE",
        "path": "/documents/{id}",
        "auth": "admin"
      },
      {
        "method": "POST",
        "path": "/chat",
        "auth": "member"
      },
      {
        "method": "POST",
        "path": "/chat/stream",
        "auth": "member"
      },
      {
        "method": "GET",
        "path": "/chat/sessions",
        "auth": "member"
      },
      {
        "method": "GET",
        "path": "/tree/{id}",
        "auth": "member"
      },
      {
        "method": "GET",
        "path": "/health",
        "auth": "public"
      },
      {
        "method": "GET",
        "path": "/memories",
        "auth": "member"
      },
      {
        "method": "POST",
        "path": "/memories",
        "auth": "member"
      },
      {
        "method": "PATCH",
        "path": "/memories/{id}",
        "auth": "member"
      },
      {
        "method": "DELETE",
        "path": "/memories/{id}",
        "auth": "member"
      }
    ]
    ]
  },
  "service_structure": [
    "app/services/auth",
    "app/services/documents",
    "app/services/retrieval",
    "app/services/chat",
    "app/services/chat/memory.py (UserMemoryService)",
    "app/services/system",
    "app/services/ingestion"
  ],
  "ingestion_flow": [
    "upload -> RustFS save -> enqueue task",
    "download -> parse Docling Method D",
    "Smart OCR 2-pass",
    "hierarchy validate",
    "rule-based refine",
    "store sections in PostgreSQL",
    "embed in bounded rolling batches",
    "store vectors in Qdrant with section_id",
    "persist artifact + status ready"
  ],
  "retrieval_flow": [
    "rate limit check (Redis Lua)",
    "query embedding cache lookup (Redis MD5-keyed, TTL=1h)",
    "embed query if cache miss",
    "TTL-cached document IDs (60s, invalidated on upload/delete)",
    "single Qdrant query (top_k=50-80, filtered to active docs)",
    "in-memory: group by section_id -> pick top sections (>=0.30)",
    "in-memory: re-rank chunks within top sections first (>=0.35)",
    "return chunks + citations"
  ],
  "security_rules": [
    "Atomic Redis Lua rate limiting",
    "Password complexity enforcement",
    "JWT HS256 with revocation blacklist",
    "Hard-delete workflow enforced",
    "Filename/path traversal protections",
    "Correlation ID propagation",
    "Security audit logging"
  ],
  "anti_patterns": [
    "flat chunking without hierarchy",
    "direct provider SDK calls in routes",
    "raw numeric HTTP status codes",
    "direct raise HTTPException in guarded API layer",
    "hallucinated answers without retrieval grounding"
  ],
  "ai_code_style": {
    "priority": [
      "Make the smallest correct change",
      "Preserve public APIs and route contracts",
      "Prefer existing service layers and adapters over new abstractions",
      "Keep functions small and single-purpose",
      "Use current naming, logging, and error patterns"
    ],
    "do": [
      "Read AGENTS.md first, then the quick reference, then task docs",
      "Update docs when behavior changes",
      "Reuse existing types, constants, and helper functions",
      "Add tests or validation when changing contracts or data flow",
      "Keep async boundaries intact for upload, retrieval, and cleanup"
    ],
    "do_not": [
      "Invent new architecture unless existing docs require it",
      "Rewrite large unrelated files during small fixes",
      "Change endpoint names or response fields silently",
      "Mix provider-specific SDK code into route handlers",
      "Return confident answers without grounded evidence"
    ]
  },
  "run_commands": {
    "compose_up": "docker compose up --build",
    "health": "curl http://localhost/api/v1/health",
    "api_logs": "docker compose logs -f api",
    "worker_logs": "docker compose logs -f upload-pipeline",
    "db_shell": "docker exec -it chatbot-rag-db-1 psql -U db-admin -d ragbot",
    "nginx_health": "curl http://localhost/nginx_status"
  }
}