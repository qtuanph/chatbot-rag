# ===================================================================
# chatbot-rag — Environment Configuration (TEMPLATE)
# ===================================================================
# IMPORTANT: This is a TEMPLATE file only!
# -------------------------------------------------------------------
# 1. Copy this file to .env for LOCAL DEVELOPMENT only.
# 2. Customize values in .env (NEVER edit .env.example)
# 3. Commit .env.example to git (safe to share)
# 4. NEVER commit .env (contains secrets)
# 5. Production must inject secrets through env/secret manager, not this file.
# ===================================================================

# -- Application ----------------------------------------------------
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# -- Webapp (Next.js) ----------------------------------------------
# Public URL — must match what users see in the browser
NEXTAUTH_URL=http://localhost
# Cloudflare Tunnel example:
# NEXTAUTH_URL=https://your-subdomain.your-domain.tld
# Signing secret for NextAuth JWT tokens (min 32 chars)
NEXTAUTH_SECRET=replace-with-a-random-string-at-least-32-chars
# Browser-side API proxy path — all API calls go through Next.js Route Handler
NEXT_PUBLIC_API_URL=/api/bep
# Server-side (internal Docker network) API URL — webapp calls backend directly
API_INTERNAL_URL=http://api:8000/api/v1

# -- Security ------------------------------------------------------
RATE_LIMIT_RELAXED_MODE=false
RATE_LIMIT_RELAXED_FLOOR=10000
# Allowed CORS/Host origins. Production: specific hostnames only.
ALLOWED_HOSTS=localhost,127.0.0.1,api,api:8000,webapp,webapp:3000
# Cloudflare Tunnel example:
# ALLOWED_HOSTS=localhost,127.0.0.1,api,api:8000,webapp,webapp:3000,your-subdomain.your-domain.tld

# -- AI Proxy (9Router) ------------------------------------------
# 9Router manages all AI model access — no direct SDK calls from routes.
# Configure providers via 9Router Dashboard (port 2908).
AI_PROXY_URL=http://ai-proxy:2908
# Model names must match 9Router provider config (via Dashboard)
AI_PROXY_DEFAULT_MODEL=chatbot-rag
AI_SUBMODEL=submodel
# 9Router API key (set in 9Router Dashboard ? API Keys)
AI_PROXY_API_KEY=replace-me
AI_PROXY_TIMEOUT=120.0

# -- AI Providers (Managed via Admin UI) --------------------------
# Embedding, Reranker, and LLM providers are managed via SQLite
# through the admin settings page at /admin/providers.
# Defaults on first boot (seeded automatically):
#   Embedding: TEI local (ai-embedding:80/v1)
#   Reranker:  TEI local (ai-reranker:80)
#   LLM:       9Router (ai-proxy:2908/v1)
# To override defaults, add/activate providers in the Admin UI.

# -- HuggingFace Token ---------------------------------------------
HF_TOKEN=replace-me

# -- LlamaParse Cloud (OCR for complex files) ---------------------
LLAMA_CLOUD_API_KEY=replace-me

# -- Vector Store (Qdrant) -----------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# -- PostgreSQL ----------------------------------------------------
POSTGRES_DB=ragbot
POSTGRES_USER=db-admin
# Admin password for PostgreSQL superuser (db-admin role)
POSTGRES_PASSWORD=replace-me
# App read-write user password (app_rw role — used by application)
APP_DB_USER=app_rw
APP_DB_PASSWORD=replace-me
# SQLAlchemy connection string for app_rw user
DATABASE_URL=postgresql+psycopg://app_rw:replace-me@db:5432/ragbot

# -- Redis ---------------------------------------------------------
# Password for Redis authentication
REDIS_PASSWORD=replace-me

# -- JWT Authentication --------------------------------------------
# Signing secret for JWT tokens (generate with: openssl rand -base64 32)
JWT_SECRET=replace-me

# -- Object Storage (RustFS — S3-compatible) -----------------------
S3_ENDPOINT=rustfs:9000
S3_ACCESS_KEY=rustfs
S3_SECRET_KEY=replace-me
S3_BUCKET=rag-documents
S3_SECURE=false
# RustFS credentials (for docker-compose healthcheck)
RUSTFS_ACCESS_KEY=rustfs
RUSTFS_SECRET_KEY=replace-me

# -- CORS ----------------------------------------------------------
CORS_ORIGINS=http://localhost
# Cloudflare Tunnel example:
# CORS_ORIGINS=http://localhost,https://your-subdomain.your-domain.tld

# -- GPU -----------------------------------------------------------
CUDA_VISIBLE_DEVICES=0

# -- Docker Build --------------------------------------------------
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# ===================================================================
# Optional Overrides (only uncomment if you need to change defaults)
# All defaults are in app/core/config.py — reranker decides quality.
# ===================================================================

# -- Upload ---------------------------------------------------------
# MAX_UPLOAD_SIZE_MB=2048

# -- Retrieval — let reranker decide, no hard filters --------------
# RETRIEVAL_SECTION_TOP_K=5           # Sections sent to LLM
# RETRIEVAL_CHUNK_TOP_K=15            # Initial candidate pool
# RETRIEVAL_FETCH_MULTIPLIER=7        # fetch_k = 15 * 7 = 105
# RETRIEVAL_RERANK_TOP_K=30           # Candidates for reranker
# RETRIEVAL_CONTEXT_EXPANSION_WINDOW=1  # Neighbor expansion (Soi sáng)
# RETRIEVAL_LONG_CONTEXT_REORDER_ENABLED=true
# RETRIEVAL_HYBRID_ENABLED=false

# -- Semantic Cache ------------------------------------------------
# RETRIEVAL_SEMANTIC_CACHE_ENABLED=true
# RETRIEVAL_SEMANTIC_CACHE_THRESHOLD=0.08  # COSINE distance (0.08 ˜ 0.92 similarity)

# -- LLM Response Cache --------------------------------------------
# LLM_CACHE_ENABLED=true
# LLM_CACHE_TTL=14400  # 4 hours

# -- Chat History --------------------------------------------------
# CHAT_HISTORY_LIMIT=40             # Max messages in Redis
# CHAT_HISTORY_REDIS_TTL=86400      # 24 hours
# AI_MAX_HISTORY_MESSAGES=10        # Messages sent to LLM per turn

# -- AI Generation -------------------------------------------------
# AI_TEMPERATURE=0.3
# AI_MAX_OUTPUT_TOKENS=8192
# AI_PROXY_TIMEOUT=120.0

# -- Embedding Ingestion Workers ----------------------------------
# EMBED_PARALLELISM=0
# 0 = auto safe mode (uses min(4, hardware.embed_parallelism), always >= 1)
