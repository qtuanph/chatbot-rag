# ===================================================================
# chatbot-rag â€” Environment Configuration (TEMPLATE)
# ===================================================================
# IMPORTANT: This is a TEMPLATE file only!
# -------------------------------------------------------------------
# 1. Copy this file to .env for LOCAL DEVELOPMENT only.
# 2. Customize values in .env (NEVER edit .env.example)
# 3. Commit .env.example to git (safe to share)
# 4. NEVER commit .env (contains secrets)
# 5. Production must inject secrets through env/secret manager, not this file.
# ===================================================================

# â”€â”€ Application â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# â”€â”€ Webapp (Next.js) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Public URL â€” must match what users see in the browser
NEXTAUTH_URL=http://localhost
# Signing secret for NextAuth JWT tokens (min 32 chars, generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=replace-with-a-random-string-at-least-32-chars
# Browser-side API proxy path â€” all API calls go through Next.js Route Handler
NEXT_PUBLIC_API_URL=/api/bep
# Server-side (internal Docker network) API URL â€” webapp calls backend directly
API_INTERNAL_URL=http://api:8000/api/v1

# â”€â”€ Security â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
RATE_LIMIT_RELAXED_MODE=true
RATE_LIMIT_RELAXED_FLOOR=10000
# Allowed CORS/Host origins. Production: specific hostnames only.
ALLOWED_HOSTS=localhost,127.0.0.1,api,api:8000,webapp,webapp:3000

# â”€â”€ AI Provider â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
AI_PROVIDER=google
# Google AI (Gemini) API key
GOOGLE_API_KEY=replace-me
GOOGLE_MODEL=gemma-4-26b-a4b-it
# Google AI Base URL (for proxies or alternative endpoints)
AI_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Internal URL for standalone AI Engine (for remote embedding/reranking)
AI_ENGINE_URL=http://ai-engine:8000

# â”€â”€ Ingestion Pipeline â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
INGESTION_ENGINE=docling
INGESTION_MIN_NON_EMPTY_NODES=1
INGESTION_MIN_TOTAL_TEXT_CHARS=80
INGESTION_EMBED_PARALLELISM=0
# Minimum OCR/Parsing quality score (0.0-1.0)
INGESTION_MIN_QUALITY_SCORE=0.5
# Hard timeout for document parsing/OCR (seconds)
INGESTION_PARSING_TIMEOUT=3600
INGESTION_EMBEDDING_CHUNK_SIZE=32

# â”€â”€ Embedding Model â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Local offline model â€” AITeamVN/Vietnamese_Embedding_v2
# 1024-dim, 8192 max tokens, Vietnamese-optimized, GPU fp16 / CPU ONNX
EMBEDDING_MODEL=sentence-transformer
EMBEDDING_HF_MODEL=AITeamVN/Vietnamese_Embedding_v2
EMBEDDING_VECTOR_SIZE=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_NORMALIZE=true

# â”€â”€ Vector Store (Qdrant) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
VECTOR_STORE=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=documents_vectors
QDRANT_TIMEOUT=30

# â”€â”€ Retrieval Quality â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
RETRIEVAL_MIN_SCORE=0.35
RETRIEVAL_SECTION_TOP_K=3
RETRIEVAL_CHUNK_TOP_K=5
RETRIEVAL_CHUNK_SIZE=400
RETRIEVAL_CHUNK_OVERLAP=75
RETRIEVAL_SECTION_MIN_SCORE=0.30
# Neighbor expansion window (Soi sÃ¡ng) â€” fetches +/- N nodes for context completeness
RETRIEVAL_CONTEXT_EXPANSION_WINDOW=1

# â”€â”€ Hybrid Search (Dense + BM25) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
RETRIEVAL_BM25_K1=1.5
RETRIEVAL_BM25_B=0.75
# BM25 vocab rebuild batch size (chunks fetched from Qdrant per loop)
RETRIEVAL_BM25_REBUILD_BATCH_SIZE=500

# â”€â”€ Cross-encoder Reranker â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
RETRIEVAL_RERANK_TOP_K=5
RETRIEVAL_RERANK_MODEL=AITeamVN/Vietnamese_Reranker

# â”€â”€ Multi-query Expansion (default OFF â€” opt-in) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
RETRIEVAL_QUERY_EXPANSION_ENABLED=false
RETRIEVAL_QUERY_EXPANSION_VARIANTS=3

# â”€â”€ PostgreSQL â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
POSTGRES_DB=ragbot
POSTGRES_USER=db-admin
# Admin password for PostgreSQL superuser (db-admin role)
POSTGRES_PASSWORD=replace-me
# App read-write user password (app_rw role â€” used by application)
APP_DB_USER=app_rw
APP_DB_PASSWORD=replace-me
# SQLAlchemy connection string for app_rw user
DATABASE_URL=postgresql+psycopg://app_rw:replace-me@db:5432/ragbot

# â”€â”€ Redis â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Password for Redis authentication (production: use a strong random password)
REDIS_PASSWORD=replace-me
# Redis URLs â€” code reads REDIS_PASSWORD and injects auth automatically
REDIS_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
# BM25 Singleton in-memory cache TTL (seconds)
BM25_SINGLETON_TTL=120

# â”€â”€ JWT Authentication â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Signing secret for JWT tokens (generate with: openssl rand -base64 32)
JWT_SECRET=replace-me
MAX_UPLOAD_SIZE_MB=50

# â”€â”€ Object Storage (RustFS â€” S3-compatible) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
STORAGE_BACKEND=s3
S3_ENDPOINT=rustfs:9000
S3_ACCESS_KEY=rustfs
S3_SECRET_KEY=replace-me
S3_BUCKET=rag-documents
S3_SECURE=false
RUSTFS_ACCESS_KEY=rustfs
RUSTFS_SECRET_KEY=replace-me

# â”€â”€ Infrastructure & Hardware â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Resource Allocation (Docker Compose)
API_CPU_LIMIT=2.0
API_MEM_LIMIT=4G
API_CPU_RESERVATION=0.5
API_MEM_RESERVATION=1G

WORKER_CPU_LIMIT=2.0
WORKER_MEM_LIMIT=4G
WORKER_CPU_RESERVATION=0.5
WORKER_MEM_RESERVATION=1G

AI_ENGINE_CPU_LIMIT=4.0
AI_ENGINE_MEM_LIMIT=8G
AI_ENGINE_CPU_RESERVATION=1.0
AI_ENGINE_MEM_RESERVATION=2G
