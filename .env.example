# ===================================================================
# chatbot-rag — Environment Configuration (TEMPLATE)
# ===================================================================
# IMPORTANT: This is a TEMPLATE file only!
# -------------------------------------------------------------------
# 1. Copy this file to .env for LOCAL DEVELOPMENT only.
# 2. Customize values in .env (NEVER edit .env.example)
# 3. Commit .env.example to git (safe to share)
# 4. NEVER commit .env (contains secrets)
# 5. Production must inject secrets through env/secret manager, not this file.
# ===================================================================

# ── Application ────────────────────────────────────────────────────
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# ── Webapp (Next.js) ──────────────────────────────────────────────
# Public URL — must match what users see in the browser
NEXTAUTH_URL=http://localhost
# Signing secret for NextAuth JWT tokens (min 32 chars)
NEXTAUTH_SECRET=replace-with-a-random-string-at-least-32-chars
# Browser-side API proxy path — all API calls go through Next.js Route Handler
NEXT_PUBLIC_API_URL=/api/bep
# Server-side (internal Docker network) API URL — webapp calls backend directly
API_INTERNAL_URL=http://api:8000/api/v1

# ── Security ──────────────────────────────────────────────────────
RATE_LIMIT_RELAXED_MODE=true
RATE_LIMIT_RELAXED_FLOOR=10000
# Allowed CORS/Host origins. Production: specific hostnames only.
ALLOWED_HOSTS=localhost,127.0.0.1,api,api:8000,webapp,webapp:3000

# ── AI Proxy (9Router) ──────────────────────────────────────────
# 9Router manages all AI model access — no direct SDK calls from routes.
# Configure providers via 9Router Dashboard (port 2908).
AI_PROXY_URL=http://ai-proxy:2908
# Model names must match 9Router provider config (via Dashboard)
AI_PROXY_DEFAULT_MODEL=chatbot-rag
AI_AUXILIARY_MODEL=auxiliary
# 9Router API key (set in 9Router Dashboard → API Keys)
AI_PROXY_API_KEY=replace-me
AI_PROXY_TIMEOUT=120.0
# Internal URL for standalone AI Engine (for remote embedding/reranking)
AI_ENGINE_URL=http://ai-engine:8000

# ── LlamaParse Cloud (OCR for complex files) ─────────────────────
LLAMA_CLOUD_API_KEY=replace-me
LLAMA_CLOUD_API_BASE=https://api.cloud.llamaindex.ai/api/parsing
LLAMA_CLOUD_TIMEOUT=120.0

# ── Ingestion Pipeline ────────────────────────────────────────────
INGESTION_ENGINE=docling
INGESTION_MIN_NON_EMPTY_NODES=1
INGESTION_MIN_TOTAL_TEXT_CHARS=80
INGESTION_EMBED_PARALLELISM=0
# Minimum OCR/Parsing quality score (0.0-1.0)
INGESTION_MIN_QUALITY_SCORE=0.5
# Min chars to keep a markdown section (merge smaller ones)
INGESTION_MIN_SECTION_CHARS=200
# Token→char multiplier for SentenceSplitter chunk_size
INGESTION_CHUNK_TOKEN_TO_CHAR_MULTIPLIER=3
# Hard timeout for document parsing/OCR (seconds)
INGESTION_PARSING_TIMEOUT=3600
INGESTION_EMBEDDING_CHUNK_SIZE=32
# OCR languages for Docling (comma-separated: vi,en,zh,...)
INGESTION_OCR_LANGUAGES=vi,en

# ── Embedding Model ───────────────────────────────────────────────
# Local offline model — AITeamVN/Vietnamese_Embedding_v2
# 1024-dim, 8192 max tokens, Vietnamese-optimized, GPU fp16 / CPU ONNX
EMBEDDING_MODEL=sentence-transformer
EMBEDDING_HF_MODEL=AITeamVN/Vietnamese_Embedding_v2
EMBEDDING_VECTOR_SIZE=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_NORMALIZE=true

# ── Vector Store (Qdrant) ─────────────────────────────────────────
VECTOR_STORE=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=documents_vectors
QDRANT_TIMEOUT=30
QDRANT_GROUP_SIZE=3

# ── Retrieval Quality ─────────────────────────────────────────────
RETRIEVAL_MIN_SCORE=0.0
RETRIEVAL_SECTION_TOP_K=10        # Production: 10-15 (arXiv: multi-hop needs 12-20 candidates)
RETRIEVAL_CHUNK_TOP_K=15          # Production: 15-20 (NVIDIA VDB_TOP_K=100 scaled)
RETRIEVAL_CHUNK_SIZE=400
RETRIEVAL_CHUNK_OVERLAP=75
RETRIEVAL_SECTION_MIN_SCORE=0.30
# Neighbor expansion window (Soi sáng) — fetches +/- N nodes for context completeness
RETRIEVAL_CONTEXT_EXPANSION_WINDOW=1
# Fetch multiplier: fetch_k = chunk_top_k * multiplier (candidate pool before dedup/rerank)
RETRIEVAL_FETCH_MULTIPLIER=3

# ── Hybrid Search (Dense + BM25) ──────────────────────────────────
RETRIEVAL_BM25_K1=1.5
RETRIEVAL_BM25_B=0.75
# BM25 vocab rebuild batch size (chunks fetched from Qdrant per loop)
RETRIEVAL_BM25_REBUILD_BATCH_SIZE=500

# ── Cross-encoder Reranker ────────────────────────────────────────
RETRIEVAL_RERANK_TOP_K=10         # Production: 10 (NVIDIA RERANKER_TOP_K=10)
RETRIEVAL_RERANK_MIN_SCORE=0.30   # Raw cross-encoder logit; >0 = relevant
RETRIEVAL_RERANK_MODEL=AITeamVN/Vietnamese_Reranker

# ── Multi-query Expansion — generates query variants for broader retrieval
RETRIEVAL_QUERY_EXPANSION_ENABLED=true
RETRIEVAL_QUERY_EXPANSION_VARIANTS=2   # Production: 2 (less noise, preserve intent)
# Timeouts for retrieval auxiliary services (seconds)
RETRIEVAL_QUERY_REFINEMENT_TIMEOUT=2.0
RETRIEVAL_QUERY_EXPANSION_TIMEOUT=3.0
RETRIEVAL_HYDE_TIMEOUT=1.5
RETRIEVAL_EXPANSION_SCROLL_LIMIT=100

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_DB=ragbot
POSTGRES_USER=db-admin
# Admin password for PostgreSQL superuser (db-admin role)
POSTGRES_PASSWORD=replace-me
# App read-write user password (app_rw role — used by application)
APP_DB_USER=app_rw
APP_DB_PASSWORD=replace-me
# SQLAlchemy connection string for app_rw user
DATABASE_URL=postgresql+psycopg://app_rw:replace-me@db:5432/ragbot

# ── Redis ─────────────────────────────────────────────────────────
# Password for Redis authentication
REDIS_PASSWORD=replace-me
# Redis DB assignments (config.py builds authenticated URLs automatically)
# DB 0: App cache + RediSearch (semantic cache MUST be on db 0)
REDIS_URL=redis://redis:6379/0
# DB 2: Celery broker
REDIS_BROKER_DB=2
# DB 1: Celery result backend
REDIS_RESULT_DB=1
# BM25 Singleton in-memory cache TTL (seconds)
BM25_SINGLETON_TTL=120

# ── JWT Authentication ────────────────────────────────────────────
# Signing secret for JWT tokens (generate with: openssl rand -base64 32)
JWT_SECRET=replace-me
MAX_UPLOAD_SIZE_MB=50

# ── Object Storage (RustFS — S3-compatible) ───────────────────────
STORAGE_BACKEND=s3
S3_ENDPOINT=rustfs:9000
S3_ACCESS_KEY=rustfs
S3_SECRET_KEY=replace-me
S3_BUCKET=rag-documents
S3_SECURE=false
RUSTFS_ACCESS_KEY=rustfs
RUSTFS_SECRET_KEY=replace-me

# ── Infrastructure & Hardware ────────────────────────────────────
# Resource Allocation (Docker Compose)
API_CPU_LIMIT=2.0
API_MEM_LIMIT=4G
API_CPU_RESERVATION=0.5
API_MEM_RESERVATION=1G

WORKER_CPU_LIMIT=2.0
WORKER_MEM_LIMIT=4G
WORKER_CPU_RESERVATION=0.5
WORKER_MEM_RESERVATION=1G

AI_ENGINE_CPU_LIMIT=4.0
AI_ENGINE_MEM_LIMIT=8G
AI_ENGINE_CPU_RESERVATION=1.0
AI_ENGINE_MEM_RESERVATION=2G
