APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

AI_PROVIDER=vllm
GOOGLE_API_KEY=replace-me
GOOGLE_API_KEYS=
GOOGLE_MODEL=gemini-2.5-flash
VLLM_BASE_URL=http://vllm:8000/v1

INGESTION_ENGINE=docling
INGESTION_MIN_NON_EMPTY_NODES=1
INGESTION_MIN_TOTAL_TEXT_CHARS=80

# Embedding & Vector Store Configuration (New Stack)
EMBEDDING_MODEL=bge-m3
EMBEDDING_BATCH_SIZE=32
EMBEDDING_NORMALIZE=true
VECTOR_STORE=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=documents_vectors
QDRANT_TIMEOUT=30

POSTGRES_DB=ragbot
POSTGRES_USER=db-admin
POSTGRES_PASSWORD=replace-me
APP_DB_USER=app_rw
APP_DB_PASSWORD=replace-me
DATABASE_URL=postgresql+psycopg://app_rw:replace-me@db:5432/ragbot

# pgAdmin / DB access (same as PostgreSQL above)
# Host: localhost
# Port: 5432
# Database: ragbot
# Username: db-admin
# Password: set POSTGRES_PASSWORD locally

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

JWT_SECRET=replace-me
MAX_UPLOAD_SIZE_MB=50

STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio-admin
MINIO_SECRET_KEY=replace-me
MINIO_BUCKET=rag-documents
MINIO_SECURE=false

# MinIO console available on http://localhost:9001
# Qdrant console available on http://localhost:6333/dashboard
