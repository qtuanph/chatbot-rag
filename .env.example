# ===================================================================
# chatbot-rag — Environment Configuration (TEMPLATE)
# ===================================================================
# IMPORTANT: This is a TEMPLATE file only.
# -------------------------------------------------------------------
# 1. Copy this file to `.env` for local development only.
# 2. Customize values in `.env` (never edit `.env.example` directly for secrets).
# 3. Commit `.env.example` to git.
# 4. Never commit `.env`.
# 5. Production should inject secrets via env vars / secret manager.
# ===================================================================

# -- Application ----------------------------------------------------
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# -- Webapp (Next.js) ----------------------------------------------
NEXTAUTH_URL=http://localhost
NEXTAUTH_SECRET=replace-with-a-random-string-at-least-32-chars
# Browser business requests must always go through the Next.js proxy route.
NEXT_PUBLIC_API_URL=/api/bep
# Next.js server-side internal call path to backend.
API_INTERNAL_URL=http://api:8000/api/v1

# -- Security -------------------------------------------------------
RATE_LIMIT_RELAXED_MODE=false
RATE_LIMIT_RELAXED_FLOOR=10000
ALLOWED_HOSTS=localhost,127.0.0.1,api,api:8000,webapp,webapp:3000

# -- AI Proxy (9Router) --------------------------------------------
AI_PROXY_URL=http://ai-proxy:2908
AI_PROXY_DEFAULT_MODEL=chatbot-rag
AI_SUBMODEL=submodel
AI_PROXY_API_KEY=replace-me
AI_PROXY_JWT_SECRET=replace-me
AI_PROXY_INITIAL_PASSWORD=123456
AI_PROXY_TIMEOUT=120.0

# -- AI Providers ---------------------------------------------------
# Active providers are selected from `settings.db` via Admin UI.
# Local defaults in this build:
#   Embedding: Docker Model Runner
#   Reranker:  NVIDIA NIM
#   LLM:       9Router
#
# Optional local runtime defaults / fallbacks:
AI_EMBEDDING_URL=http://model-runner.docker.internal:12434/engines/v1
AI_RERANKER_URL=http://model-runner.docker.internal:12434
RERANKER_BACKEND=nvidia
NVIDIA_API_KEY=
NVIDIA_RERANKER_MODEL=nvidia/llama-nemotron-rerank-1b-v2
NVIDIA_RERANKER_URL=https://ai.api.nvidia.com/v1/retrieval/nvidia/llama-nemotron-rerank-1b-v2/reranking
NVIDIA_RERANKER_TIMEOUT=30.0
EMBEDDING_API_BASE=http://model-runner.docker.internal:12434/engines/v1
EMBEDDING_HF_MODEL=ai/qwen3-embedding:0.6B-F16
EMBEDDING_VECTOR_SIZE=1024

# -- Hugging Face / Llama Cloud ------------------------------------
HF_TOKEN=replace-me
# Optional alias for libs that do not read `HF_TOKEN` consistently.
# HUGGING_FACE_HUB_TOKEN=replace-me
LLAMA_CLOUD_API_KEY=replace-me

# -- Vector Store (Qdrant) -----------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_SECTION_COLLECTION=documents_sections
QDRANT_CHUNK_COLLECTION=documents_chunks

# -- PostgreSQL -----------------------------------------------------
POSTGRES_DB=ragbot
POSTGRES_USER=db-admin
POSTGRES_PASSWORD=replace-me
APP_DB_USER=app_rw
APP_DB_PASSWORD=replace-me
DATABASE_URL=postgresql+psycopg://app_rw:replace-me@db:5432/ragbot

# -- Redis ----------------------------------------------------------
REDIS_PASSWORD=replace-me

# -- JWT Authentication ---------------------------------------------
JWT_SECRET=replace-me

# -- Object Storage (RustFS, S3-compatible) -------------------------
S3_ENDPOINT=rustfs:9000
S3_ACCESS_KEY=rustfs
S3_SECRET_KEY=replace-me
S3_BUCKET=rag-documents
S3_SECURE=false
RUSTFS_ACCESS_KEY=rustfs
RUSTFS_SECRET_KEY=replace-me

# -- CORS -----------------------------------------------------------
CORS_ORIGINS=http://localhost

# -- GPU ------------------------------------------------------------
CUDA_VISIBLE_DEVICES=0

# -- Docker Build ---------------------------------------------------
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# ===================================================================
# Optional Overrides
# ===================================================================

# -- Upload ---------------------------------------------------------
# MAX_UPLOAD_SIZE_MB=2048

# -- Retrieval ------------------------------------------------------
# RETRIEVAL_CHUNK_TOP_K=20
# RETRIEVAL_SECTION_TOP_K=8
# RETRIEVAL_RECURSIVE_TOP_K=8
# RETRIEVAL_RERANK_TOP_K=10
# RETRIEVAL_HYBRID_TOP_K=20
# RETRIEVAL_HYBRID_ENABLED=true
# RETRIEVAL_LONG_CONTEXT_REORDER_ENABLED=true
# RETRIEVAL_HIERARCHICAL_CHUNK_SIZES=[2048,768]
# RETRIEVAL_SENTENCE_WINDOW_SIZE=3
# RETRIEVAL_AUTO_MERGE_RATIO_THRESHOLD=0.5
# RETRIEVAL_ROUTE_SECTION_MAX_CHARS=96
# RETRIEVAL_ROUTE_SECTION_MAX_TERMS=12
# RETRIEVAL_CONTEXT_MAX_CHARS=30000
# RETRIEVAL_SECTION_HYDRATION_ENABLED=true
# RETRIEVAL_SECTION_HYDRATION_TOP_K=6
# RETRIEVAL_HISTORY_QUERY_COUNT=0   # 0 = retrieval only uses the latest user query
# RETRIEVAL_RERANK_SKIP_ENABLED=true
# RETRIEVAL_RERANK_SKIP_QUERY_MAX_CHARS=48
# RETRIEVAL_RERANK_SKIP_QUERY_MAX_TERMS=8
# RETRIEVAL_RERANK_SKIP_DOMINANCE_RATIO=1.35
# QDRANT_SEARCH_INDEXED_ONLY=false

# -- Stateless Chat -------------------------------------------------
# AI_MAX_HISTORY_MESSAGES=6         # recent messages only for LLM conversation context

# -- AI Generation --------------------------------------------------
# AI_TEMPERATURE=0.3
# AI_MAX_OUTPUT_TOKENS=8192

# -- Embedding / Ingestion -----------------------------------------
# EMBEDDING_BATCH_SIZE=16
# EMBED_PARALLELISM=0
# INGESTION_PIPELINE_BATCH_SIZE=8
# DOCUMENT_PROGRESS_STREAM_INTERVAL=1.0
