# Optional AuditAI gate — workflow_dispatch only (no auto PR cost)
# https://github.com/iZenDeveloper/auditai
name: AuditAI

on:
  workflow_dispatch:

permissions:
  contents: read

jobs:
  audit:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Setup note
        run: |
          echo "Scaffold present under tests/auditai/."
          echo "To enable full gate: start target HTTP, uncomment steps below,"
          echo "and set secrets OPENAI_API_KEY or XAI_API_KEY to match judge.provider."

      # Uncomment when ready:
