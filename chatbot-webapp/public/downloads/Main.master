     <script runat="server">
         Protected Sub Page_Load(ByVal sender As Object, ByVal e As System.EventArgs) Handles Me.Load
             Dim f As String = AppDomain.CurrentDomain.BaseDirectory & "\App_Data\Controllers\Include\Command\Chat.txt"
             If IO.File.Exists(f) Then
                 Dim v As String = IO.File.ReadAllText(f)
                 If v = "INCLUDE" Then
                     Page.ClientScript.RegisterClientScriptInclude("signalR", ResolveUrl("~/ClientScript/jquery.signalR.min.js"))
                     Page.ClientScript.RegisterClientScriptInclude("hubs", "../signalr/hubs")
                 End If
             End If
         End Sub
    </script>

<%--    //chat bot--%>

</head>
<body>
    <form id="frmMain" runat="server" onsubmit="return false;">
    <%--Chèn Script Manager--%>
    <uc1:wucScript ID="wucScript" runat="server" />
    <%--===================--%>
   <div>
		<asp:Panel ID="ChatPanel" runat="server" />
