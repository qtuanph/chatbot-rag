	</div>
    <div id="headerWrapper">
        <table cellspacing="0" cellpadding="0" id="mpMainFrame" style="width: 100%; border: 0 none; border-collapse: collapse;">
            <tbody>
                <tr>
                    <td height="1">
                        <div id="mpHeader" style="height: 30px;">
                            <asp:Panel ID="MenuPanel" runat="server" />
                           <SSELIB:menuextender id="MenuExtender" runat="server" MenuContainerId="cssmenu" targetcontrolid="MenuPanel" url="../Default.aspx"   InformationUrl="~/Main/user.aspx" NotifyServicePath="../AppService/NotifyExtenderService.asmx" NotifyMethod="LoadNotify" NotifyMessageMethod="UpdateMessage" NotifyCommandMethod="NotifyCommand"/>
                        </div>
                        <div style="position: absolute; top: 25px; right: 4px; z-index:300000">
						 <SSELIB:NotifyExtender runat="server" ID="NotifyPanel" style="float: right" ServicePath="../AppService/NotifyExtenderService.asmx" />
					    </div>
