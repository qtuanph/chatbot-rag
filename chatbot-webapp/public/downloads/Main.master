        </table>
    </div>

    <div id="bodyWrapper">    
     <div id="footerWrapper">
        <table cellspacing="0" cellpadding="0" id="mpTableFooter" style="width: 100%; border: 0 none; border-collapse: collapse;">
            <tbody>
                <tr>
                    <td id="mpFooter">
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
        <div class="content-wrap">
            <div class="menu-wrap">
                <%--<div id="cssmemuback"></div>--%>
	            <div id="cssmenu"></div>                
            </div>
	        <div id="content">
    	        <div id="ctn-body">
        	        <div id="ctn-wrap">
            	        <div id="mpMainBody">
                            <%--TAB PANEL--%>
	                        <div id="main-tab-container" class="easyui-tabs">
		                        <div title="Home">
                                    <asp:ContentPlaceHolder ID="SSELIB_Main" runat="server">                                    
                                    </asp:ContentPlaceHolder>  
                                    <iframe src="Dashboard.aspx" style="width:100%;height:100%;" frameborder="0"></iframe>                              
		                        </div>  
	                        </div>
